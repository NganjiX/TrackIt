# Application
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1

# Database
DATABASE_URL=postgresql://smartledger:smartledger@localhost:5433/smartledger?schema=public

# JWT (Phase 3)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Rate limiting
THROTTLE_TTL=60000
THROTTLE_LIMIT=100

# Redis (Phase 3+)
REDIS_HOST=localhost
REDIS_PORT=6379

# S3 / MinIO (Phase 8)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=smartledger
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_PUBLIC_URL=http://localhost:9000/smartledger

# Mail (Phase 3)
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_SECURE=false
MAIL_USER=
MAIL_PASSWORD=
MAIL_FROM=noreply@smartledger.rw

# Google OAuth (Phase 3)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3000/api/v1/auth/google/callback

# AI (Phase 11)
AI_PROVIDER=anthropic
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Frontend URL (for email links)
FRONTEND_URL=http://localhost:5173
